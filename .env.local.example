# Copy to .env.local and fill in values. Never commit .env.local.

NEXT_PUBLIC_SITE_URL=             # http://localhost:3000 locally; https://your-app.vercel.app on Vercel
NEXT_PUBLIC_SUPABASE_URL=        # From Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # Public anon key — safe for browser
SUPABASE_SERVICE_KEY=             # Service role key — SERVER ONLY, never expose
OPENAI_API_KEY=                   # From platform.openai.com/api-keys
